#' @keywords internal
matrix_ID_conversion <- function(
  countData,
  species,
  input_datatype,
  target_datatype,
  to_rownames
) {
  if (species == "Mm") {
    conversion <- AnnotationDbi::select(
      org.Mm.eg.db::org.Mm.eg.db,
      keys = countData$Geneid,
      keytype = input_datatype,
      column = target_datatype
    )
  } else if (species == "Hs") {
    conversion <- AnnotationDbi::select(
      org.Hs.eg.db::org.Hs.eg.db,
      keys = countData$Geneid,
      keytype = input_datatype,
      column = target_datatype
    )
  } else {
    stop("Such species is not supported")
  }

  countData <- merge(
    countData,
    conversion,
    by.x = "Geneid",
    by.y = input_datatype,
    all = TRUE
  )
  countData <- subset(countData, select = -c(Geneid))
  countData <- na.omit(countData)

  pos <- which(colnames(countData) == target_datatype)

  colnames(countData)[pos] <- "Geneid"

  if (to_rownames) {
    if (TRUE %in% duplicated(na.omit(countData$Geneid))) {
      print("There are duplicated values: aggregating...")
      countData <- remove_dup(countData, index = "Geneid", method = "kmax")
    }

    row.names(countData) <- countData$Geneid
    countData$Geneid <- NULL
  }

  return(countData)
}

#' Convert Gene ID Conveniently
#'
#' @param geneList A vector of gene ids or a matrix contains a column of gene ids named "Geneid".
#' @param species A string denotes the species. "Hs" for human and "Mm" for mouse.
#' @param input_datatype A string denotes the id type in the geneList.
#' @param target_datatype A string denotes the target id type.
#' @param matrix A logical value denotes whether the geneList is a matrix. TRUE if geneList is a matrix.
#' @param single_mapping A logical value denotes whether one input gene id is mapped to only one target gene id, even though it has several alias. Default to be true.
#' @param to_rownames For matrix = TRUE only. A logical value denotes whether the converted ids are rownames of the resultant matrix. If rownames are duplicated, the resultant row takes the mean value.
#'
#' @returns A vector or matrix.
#' @export
#'
#' @examples
#' SYMBOL <- Quick_ID_conversion(ENTREZID, species = "Mm", input_datatype = "ENTREZID", target_datatype = "SYMBOL", matrix = F, single_mapping = T, to_rownames = F)
Quick_ID_conversion <- function(
  geneList,
  species,
  input_datatype,
  target_datatype,
  matrix = F,
  single_mapping = T,
  to_rownames = F
) {
  if (matrix) {
    return(matrix_ID_conversion(
      geneList,
      species,
      input_datatype,
      target_datatype,
      to_rownames
    ))
  }

  if (species == "Mm") {
    conversion <- AnnotationDbi::select(
      org.Mm.eg.db::org.Mm.eg.db,
      keys = geneList,
      keytype = input_datatype,
      column = target_datatype
    )
  } else if (species == "Hs") {
    conversion <- AnnotationDbi::select(
      org.Hs.eg.db::org.Hs.eg.db,
      keys = geneList,
      keytype = input_datatype,
      column = target_datatype
    )
  } else {
    stop("Such species is not supported")
  }

  if (single_mapping) {
    conversion <- conversion[match(geneList, conversion[, 1]), ]
  } else {
    conversion <- split(x = conversion[, 2], f = as.factor(conversion[, 1]))
    conversion <- lapply(conversion, function(x) {
      paste(x, collapse = ";")
    })
    conversion <- data.frame(
      names(conversion),
      sapply(conversion, function(x) {
        x[1]
      })
    )
  }

  return(conversion[, 2])
}


